{
  "apps": [
    {
      "name": "SmashHub-BE",
      "script": "dist/server.js",
      "instances": "4",
      "exec_mode": "cluster",
      "node_args": "--max-old-space-size=512",
      "autorestart": true,
      "max_memory_restart": "512M",
      "restart_delay": 5000,
      "watch": false,
      "time": true,
      "env": {
        "NODE_ENV": "production"
      },
      "error_file": "./logs/error.log",
      "out_file": "./logs/out.log",
      "merge_logs": true,
      "log_date_format": "YYYY-MM-DD HH:mm:ss Z",
      "kill_timeout": 5000,
      "listen_timeout": 10000
    }
  ]
}
